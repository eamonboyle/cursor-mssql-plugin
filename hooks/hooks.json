{
  "hooks": {
    "afterFileEdit": [
      {
        "command": "./scripts/format-tsql.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./scripts/validate-sql-safety.sh",
        "matcher": "rm|curl|wget|sqlcmd|Invoke-Sqlcmd|DROP\\s+TABLE|TRUNCATE"
      }
    ],
    "sessionEnd": [
      {
        "command": "./scripts/audit-sql-changes.sh"
      }
    ]
  }
}
